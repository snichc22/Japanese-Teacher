# =============================================================================
# Japanese Teacher AI — Environment Variables
# =============================================================================
# Copy this file and rename it to .env.teacher, then fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# HuggingFace
# -----------------------------------------------------------------------------
# Optional for downloading gated models (e.g. Qwen/Qwen3.5-9B-Base) during
# fine-tuning. Generate a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# -----------------------------------------------------------------------------
# Ollama / LLM  (src/llm.py)
# -----------------------------------------------------------------------------
# The Ollama model name used by the agent. Must support tool-calling.
# After running the full fine-tune pipeline, "japanese-teacher-ft" supports
# tools via the injected Qwen3.5-Instruct chat template.
# Use "japanese-teacher" to fall back to the base model at any time.
OLLAMA_MODEL=japanese-teacher
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=512
OLLAMA_KEEP_ALIVE=30m

# -----------------------------------------------------------------------------
# Agent / Tooling  (src/agent.py, src/search.py, app.py)
# -----------------------------------------------------------------------------
AGENT_VERBOSE=false
AGENT_MAX_ITERATIONS=2

# Maximum number of web results fetched from DuckDuckGo per tool call.
SEARCH_MAX_RESULTS=5

# Number of top search results summarized into the prompt.
SEARCH_MAX_RETURNED_RESULTS=3

# Max characters kept per search snippet in tool output.
SEARCH_MAX_SNIPPET_CHARS=220

# Number of conversation turns (user+assistant pairs) kept in prompt history.
CHAT_HISTORY_TURNS=6

# -----------------------------------------------------------------------------
# Fine-tune export  (finetune/convert_to_ollama.py)
# -----------------------------------------------------------------------------
# q8_0 is much faster than f16 on many local setups while keeping good quality.
GGUF_OUTTYPE=q8_0

# -----------------------------------------------------------------------------
# RAG / Document Storage  (src/rag.py)
# -----------------------------------------------------------------------------
# Directory where uploaded learning materials (PDFs, .txt, .md) are stored.
DOCUMENT_DIR=documents

# Directory where the ChromaDB vector store index is persisted.
VECTORSTORE_DIR=vectorstore

# Device used for computing HuggingFace embeddings.
# Set to "cuda" to force GPU, "cpu" to force CPU, or leave blank to auto-detect.
EMBEDDING_DEVICE=
